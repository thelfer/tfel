@Requires {"mfront::material_property::generic-parallel_interface::supported_configuration::stlpar-parunseq-gcc"};

@Environment {"LD_LIBRARY_PATH": "src"};
@Command "@mfront@ --obuild --interface=generic-parallel --configuration-file=config-stlpar-parunseq-gcc.json ../PoissonRatioTest.mfront";
@Command "@mfront@ --obuild --interface=generic-parallel --configuration-file=config-stlpar-parunseq-gcc.json ../Inconel600_YoungModulus.mfront";
@Command "@mfront@ --obuild --interface=generic-parallel --configuration-file=config-stlpar-parunseq-gcc.json ../Inconel600_YoungModulus-qt.mfront";
@Command "@TFEL_GXX_COMPILER@ -I @TFEL_INCLUDE_DIR@ -I include -O2 -march=native --std=c++@TFEL_CXX_STANDARD@ ../test-stlpar.cxx -o test-stlpar -L @TFEL_LIBRARY_DIR@ -lTFELTests -L src -lGenericParallelInconel600-stlpar -lGenericParallelMaterialLaw-stlpar";
@Command "./test-stlpar test-stlpar-parunseq-gcc";

@CleanFiles {"test-stlpar"};
@CleanDirectories {"include", "src"};