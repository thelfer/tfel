@Requires {"mfront::material_property::generic-parallel_interface::supported_configuration::sycl-gpu-acpp"};

@Environment {"LD_LIBRARY_PATH": "src"};
@Command "@mfront@ --interface=generic-parallel --configuration-file=config-sycl-default-acpp.json ../PoissonRatioTest.mfront";
@Command "@mfront@ --interface=generic-parallel --configuration-file=config-sycl-default-acpp.json ../Inconel600_YoungModulus.mfront";
@Command "@mfront@ --interface=generic-parallel --configuration-file=config-sycl-default-acpp.json ../Inconel600_YoungModulus-qt.mfront";
@Command "@mfront@ --obuild --configuration-file=config-sycl-default-acpp.json";
@Command "@TFEL_ACPP_COMPILER@ -DTFEL_SYCL_DEVICE=1 -I @TFEL_INCLUDE_DIR@ -I include -O2 -march=native --std=c++@TFEL_CXX_STANDARD@ ../test-sycl.cxx -o test-sycl -L @TFEL_LIBRARY_DIR@ -lTFELTests -L src -lGenericParallelInconel600-sycl -lGenericParallelMaterialLaw-sycl";
@Command "./test-sycl test-sycl-gpu-acpp";

@CleanFiles {"test-sycl"};
@CleanDirectories {"include", "src"};