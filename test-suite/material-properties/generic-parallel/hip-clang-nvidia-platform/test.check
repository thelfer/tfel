@Requires {"mfront::material_property::generic-parallel_interface::supported_configuration::hip-clang-nvidia-platform"};

@Environment {"LD_LIBRARY_PATH": "src"};
@Environment {"LD_LIBRARY_PATH": "src"};
@Command "@mfront@ --obuild --interface=generic-parallel --configuration-file=../configuration-files/config-hip-clang-nvidia-platform.json ../PoissonRatioTest.mfront";
@Command "@mfront@ --obuild --interface=generic-parallel --configuration-file=../configuration-files/config-hip-clang-nvidia-platform.json ../Inconel600_YoungModulus.mfront";
@Command "@mfront@ --obuild --interface=generic-parallel --configuration-file=../configuration-files/config-hip-clang-nvidia-platform.json ../Inconel600_YoungModulus-qt.mfront";
@Command "@TFEL_CLANGXX_COMPILER@ -D__HIP_PLATFORM_NVIDIA__ -O3 --std=c++@TFEL_CXX_STANDARD@ -march=native -x cuda --cuda-path=@TFEL_CUDA_PATH@ --cuda-compile-host-device --cuda-gpu-arch=native -isystem @TFEL_HIP_INCLUDE_DIR@ -I @TFEL_INCLUDE_DIR@ -I include ../test-hip.hip -o test-hip -L @TFEL_LIBRARY_DIR@ -lTFELTests -L src -lGenericParallelInconel600-hip -lGenericParallelMaterialLaw-hip -L@TFEL_CUDA_LIBRARY_DIR@ -lcudart -ldl -lrt -pthread";
@Command "./test-hip test-hip-hipcc";

@CleanDirectories {"include", "src"};