dsl_options: {
  disable_runtime_checks: false
},
interfaces_options: {
  generic-parallel: {
    backend: {stlpar: {
        execution_policy: "parallel_unsequenced_policy"
      }
    }
  }
},
compilation_options : {
  cxx : {
    compiler: "@TFEL_NVHPC_COMPILER@",
    compilation_flags: "-O2 -stdpar=gpu -std=c++@TFEL_CXX_STANDARD@ -march=native" 
  }
},
linking_options : {
  linker_flags: "-stdpar=gpu"
}