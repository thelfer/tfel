dsl_options: {
  disable_runtime_checks: false
},
interfaces_options: {
  generic-parallel: {
    backend: {cuda : {
        number_of_threads_per_block: 64
      }
    }
  }
},
compilation_options : {
  cuda : {
    compiler: "@TFEL_NVCC_COMPILER@",
    compilation_flags: "-O2 -std=c++@TFEL_CXX_STANDARD@ -diag-suppress 20012 -Xcompiler -fPIC --expt-relaxed-constexpr"
  }
}