dsl_options: {
  disable_runtime_checks: false
},
interfaces_options: {
  generic-parallel: {
    backend: {hip: {
        number_of_threads_per_block: 64
      }
    }
  }
},
compilation_options : {
  hip: {
    compiler: "@TFEL_HIPCC_COMPILER@",
    compilation_flags: "-x cu --compiler-options=-fPIC --std=c++@CMAKE_CXX_STANDARD@ --expt-relaxed-constexpr -isystem @TFEL_HIP_INCLUDES@ -diag-suppress 20012"
  }
}