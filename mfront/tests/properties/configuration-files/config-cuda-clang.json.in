interfaces_options: {
  generic-parallel: {
    backend: {cuda : {
        number_of_threads_per_block: 64
      }
    }
  }
},
compilation_options : {
  cxx : {
    compiler: "clang++",
    compilation_flags: "-std=c++@CMAKE_CXX_STANDARD@ -O3 -march=native" 
  },
  cuda : {
    compiler: "clang++",
    compilation_flags: {"-O3 -std=c++@CMAKE_CXX_STANDARD@ -march=native",
      "-x cuda --cuda-compile-host-device ",
      "--cuda-path=@TFEL_CUDA_PATH@ -fPIC -DPIC"}
  }
},
linking_options: {
  linker_flags: "-L@CUDAToolkit_LIBRARY_DIR@ -lcudart -ldl -lrt -pthread"
}