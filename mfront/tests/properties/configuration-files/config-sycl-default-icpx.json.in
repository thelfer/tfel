interfaces_options: {
  generic-parallel: {
    backend: sycl {
     data_location: "host"
    }
  }
},
compilation_options : {
  cxx : {
    compiler: "@TFEL_ICPX_COMPILER@",
    compilation_flags: "-O2 -std=c++@CMAKE_CXX_STANDARD@ -march=native -fsycl" 
  }
},
linking_options : {
  linker_flags : "-fsycl"
}
